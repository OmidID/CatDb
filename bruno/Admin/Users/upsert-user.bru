meta {
  name: Create or Update User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/admin/users
  body: json
  auth: basic
}

auth:basic {
  username: {{adminUser}}
  password: {{adminPassword}}
}

body:json {
  {
    "userName": "{{userName}}",
    "password": "changeme",
    "globalPermissions": "ListDatabases",
    "databasePermissions": {
      "mydb": "Read, Write"
    }
  }
}
